<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="NativeGuard_App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:NativeGuard_App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Native Guard"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Native Guard">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1" Padding="16" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="非原生进程" />

                <Button
                    Grid.Column="1"
                    Click="RefreshButton_Click"
                    Content="刷新" />
            </Grid>

            <ListView
                Grid.Row="1"
                ItemsSource="{x:Bind Rows, Mode=OneWay}"
                SelectionMode="None">
                <ListView.Header>
                    <Grid Padding="8,0,8,4" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="160" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="进程" />
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="PID" />
                        <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="架构" />
                        <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="CPU 时间" />
                        <TextBlock Grid.Column="5" FontWeight="SemiBold" Text="操作" />
                        <TextBlock Grid.Column="6" FontWeight="SemiBold" Text="状态" />
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="160" />
                            </Grid.ColumnDefinitions>
                            <Image
                                Width="20"
                                Height="20"
                                VerticalAlignment="Center"
                                Source="{Binding Icon}" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="{Binding Name}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{Binding ProcessId}" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{Binding Architecture}" />
                            <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{Binding CpuTime}" />
                            <Button
                                Grid.Column="5"
                                Click="TerminateButton_Click"
                                Content="结束"
                                DataContext="{Binding}" />
                            <TextBlock
                                Grid.Column="6"
                                VerticalAlignment="Center"
                                Text="{Binding Status}"
                                TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Window>
