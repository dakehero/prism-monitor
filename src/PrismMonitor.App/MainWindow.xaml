<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PrismMonitor.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PrismMonitor.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Prism Monitor"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Prism Monitor">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="RootNavigationView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            Loaded="Root_Loaded"
            PaneDisplayMode="LeftCompact"
            SelectionChanged="RootNavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Processes"
                    IsSelected="True"
                    Tag="Processes">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="ViewAll" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="History"
                    Tag="History">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Library" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Filters"
                    Tag="Filters">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Filter" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid Padding="16">
                <Grid
                    x:Name="ProcessesPage"
                    RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="Compatibility-mode processes" />
                            <Button Grid.Column="1" Click="RefreshButton_Click" Content="Refresh" />
                        </Grid>

                        <ListView
                            x:Name="ProcessListView"
                            Grid.Row="1"
                            ItemsSource="{x:Bind Rows, Mode=OneWay}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.HorizontalScrollMode="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollMode="Enabled"
                            SelectionMode="Single">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:ProcessRow">
                                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Expander HorizontalAlignment="Stretch">
                                            <Expander.Header>
                                                <Grid ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Image Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Center" Source="{x:Bind Icon, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        FontWeight="SemiBold"
                                                        MaxLines="1"
                                                        Text="{x:Bind Name, Mode=OneWay}"
                                                        TextAlignment="Left"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <Border
                                                        x:Name="ProcessArchitectureBadge"
                                                        Grid.Column="2"
                                                        Padding="6,2"
                                                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="4">
                                                        <TextBlock FontSize="12" Text="{x:Bind Architecture, Mode=OneWay}" TextAlignment="Left" />
                                                    </Border>
                                                    <TextBlock
                                                        x:Name="ProcessSummaryLine"
                                                        Grid.Column="3"
                                                        VerticalAlignment="Center"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{x:Bind SummaryLine, Mode=OneWay}"
                                                        TextAlignment="Left" />
                                                </Grid>
                                            </Expander.Header>
                                            <StackPanel Padding="48,0,8,10" Spacing="8">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="84" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="PID" TextAlignment="Left" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind ProcessId, Mode=OneWay}" TextAlignment="Left" />
                                                    <Button
                                                        x:Name="CopyProcessIdButton"
                                                        Grid.Column="2"
                                                        Click="CopyValueButton_Click"
                                                        Content="Copy"
                                                        Tag="{x:Bind ProcessId, Mode=OneWay}" />
                                                </Grid>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="84" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="CPU time" TextAlignment="Left" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind CpuTime, Mode=OneWay}" TextAlignment="Left" />
                                                </Grid>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="84" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Path" TextAlignment="Left" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                        IsTextSelectionEnabled="True"
                                                        Text="{x:Bind ExecutablePath, Mode=OneWay}"
                                                        TextAlignment="Left"
                                                        TextWrapping="Wrap"
                                                        ToolTipService.ToolTip="{x:Bind ExecutablePath, Mode=OneWay}" />
                                                    <Button
                                                        x:Name="CopyProcessPathButton"
                                                        Grid.Column="2"
                                                        Click="CopyValueButton_Click"
                                                        Content="Copy"
                                                        Tag="{x:Bind ExecutablePath, Mode=OneWay}" />
                                                </Grid>
                                                <Button HorizontalAlignment="Left" Content="Actions">
                                                    <Button.Flyout>
                                                        <MenuFlyout>
                                                            <MenuFlyoutItem Click="TerminateMenuItem_Click" Tag="{x:Bind}" Text="End process" />
                                                            <MenuFlyoutItem Click="IgnoreProcessMenuItem_Click" Tag="{x:Bind}" Text="Ignore process" />
                                                        </MenuFlyout>
                                                    </Button.Flyout>
                                                </Button>
                                            </StackPanel>
                                        </Expander>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                </Grid>

                <Grid
                    x:Name="HistoryPage"
                    RowSpacing="12"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ScrollViewer
                        x:Name="HistoryFilterScrollViewer"
                        HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Disabled">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="144" />
                                <ColumnDefinition Width="144" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="HistorySearchTextBox"
                                PlaceholderText="Search history"
                                TextChanged="HistoryFilter_Changed" />
                            <ComboBox
                                x:Name="HistoryArchitectureComboBox"
                                Grid.Column="1"
                                SelectedIndex="0"
                                SelectedValuePath="Tag"
                                SelectionChanged="HistoryFilter_Changed"
                                x:SuppressXamlTrimWarnings="True">
                                <ComboBoxItem Content="All" Tag="All" />
                                <ComboBoxItem Content="x86" Tag="x86" />
                                <ComboBoxItem Content="x64" Tag="x64" />
                                <ComboBoxItem Content="ARM64EC" Tag="ARM64EC" />
                            </ComboBox>
                            <ComboBox
                                x:Name="HistoryIgnoredStateComboBox"
                                Grid.Column="2"
                                SelectedIndex="0"
                                SelectedValuePath="Tag"
                                SelectionChanged="HistoryFilter_Changed"
                                x:SuppressXamlTrimWarnings="True">
                                <ComboBoxItem Content="All" Tag="All" />
                                <ComboBoxItem Content="Ignored" Tag="Ignored" />
                                <ComboBoxItem Content="Not ignored" Tag="Not ignored" />
                            </ComboBox>
                            <Button
                                Grid.Column="3"
                                Click="RefreshHistoryButton_Click"
                                Content="Refresh" />
                        </Grid>
                    </ScrollViewer>

                    <ListView
                        x:Name="HistoryListView"
                        Grid.Row="1"
                        ItemsSource="{x:Bind HistoryRows, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollMode="Enabled"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:HistoryRow">
                                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Expander HorizontalAlignment="Stretch">
                                        <Expander.Header>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Image Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Center" Source="{x:Bind Icon, Mode=OneWay}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    FontWeight="SemiBold"
                                                    MaxLines="1"
                                                    Text="{x:Bind ProcessName, Mode=OneWay}"
                                                    TextAlignment="Left"
                                                    TextTrimming="CharacterEllipsis" />
                                                <Border
                                                    x:Name="HistoryArchitectureBadge"
                                                    Grid.Column="2"
                                                    Padding="6,2"
                                                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                                    VerticalAlignment="Center"
                                                    CornerRadius="4">
                                                    <TextBlock FontSize="12" Text="{x:Bind Architecture, Mode=OneWay}" TextAlignment="Left" />
                                                </Border>
                                                <TextBlock
                                                    x:Name="HistorySummaryLine"
                                                    Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{x:Bind SummaryLine, Mode=OneWay}"
                                                    TextAlignment="Left" />
                                                <TextBlock
                                                    Grid.Column="4"
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{x:Bind IgnoredText, Mode=OneWay}"
                                                    TextAlignment="Left" />
                                            </Grid>
                                        </Expander.Header>
                                        <StackPanel Padding="48,0,8,10" Spacing="8">
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="84" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="PID" TextAlignment="Left" />
                                                <TextBlock Grid.Column="1" Text="{x:Bind LastProcessId, Mode=OneWay}" TextAlignment="Left" />
                                                <Button
                                                    x:Name="CopyHistoryProcessIdButton"
                                                    Grid.Column="2"
                                                    Click="CopyValueButton_Click"
                                                    Content="Copy"
                                                    Tag="{x:Bind LastProcessId, Mode=OneWay}" />
                                            </Grid>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="84" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Seen" TextAlignment="Left" />
                                                <TextBlock
                                                    x:Name="HistoryMetaLine"
                                                    Grid.Column="1"
                                                    Text="{x:Bind TimeRangeLine, Mode=OneWay}"
                                                    TextAlignment="Left" />
                                            </Grid>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="84" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Path" TextAlignment="Left" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                    IsTextSelectionEnabled="True"
                                                    Text="{x:Bind ExecutablePath, Mode=OneWay}"
                                                    TextAlignment="Left"
                                                    TextWrapping="Wrap"
                                                    ToolTipService.ToolTip="{x:Bind ExecutablePath, Mode=OneWay}" />
                                                <Button
                                                    x:Name="CopyHistoryPathButton"
                                                    Grid.Column="2"
                                                    Click="CopyValueButton_Click"
                                                    Content="Copy"
                                                    Tag="{x:Bind ExecutablePath, Mode=OneWay}" />
                                            </Grid>
                                        </StackPanel>
                                    </Expander>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <Grid
                    x:Name="FiltersPage"
                    RowSpacing="16"
                    Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Ignored apps" />

                        <Grid Grid.Row="1" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="IgnoreNameTextBox" PlaceholderText="Process name to ignore" />
                            <Button Grid.Column="1" Click="AddIgnoredButton_Click" Content="Add ignored app" />
                        </Grid>

                        <ListView
                            x:Name="FilterListView"
                            Grid.Row="2"
                            ItemsSource="{x:Bind FilterRows, Mode=OneWay}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.HorizontalScrollMode="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollMode="Enabled"
                            SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.Header>
                                <TextBlock HorizontalAlignment="Left" Margin="0,0,0,8" FontWeight="SemiBold" Text="Ignored apps" TextAlignment="Left" />
                            </ListView.Header>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:FilterRow">
                                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid Padding="8,6" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Text="{x:Bind Name, Mode=OneTime}" TextAlignment="Left" TextTrimming="CharacterEllipsis" />
                                            <Button Grid.Column="1" HorizontalAlignment="Left" Click="RemoveIgnoredButton_Click" Content="Remove" Tag="{x:Bind Name, Mode=OneTime}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                </Grid>

                <Grid
                    x:Name="SettingsPage"
                    RowSpacing="16"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Settings" />

                    <ScrollViewer
                        x:Name="SettingsScrollViewer"
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        VerticalScrollMode="Enabled">
                        <StackPanel Spacing="20" MaxWidth="720" HorizontalAlignment="Left">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="SemiBold" Text="Monitoring" />
                                <ToggleSwitch
                                    x:Name="IncludeArm64EcToggle"
                                    Header="Include ARM64EC / ARM64X"
                                    Toggled="IncludeArm64EcToggle_Toggled" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Power-aware refresh pauses while the main window is hidden."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" />

                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="SemiBold" Text="Notifications" />
                                <ComboBox
                                    x:Name="NotificationLevelComboBox"
                                    Header="Notify for"
                                    Width="240"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{x:Bind NotificationLevelOptions, Mode=OneWay}"
                                    SelectionChanged="NotificationLevelComboBox_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="local:NotificationLevelOption">
                                            <TextBlock Text="{x:Bind DisplayName, Mode=OneTime}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" />

                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="SemiBold" Text="Permissions" />
                                <TextBlock
                                    x:Name="ElevationStatusTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                                <Button
                                    x:Name="RelaunchAsAdministratorButton"
                                    Click="RelaunchAsAdministratorButton_Click"
                                    Content="Restart as administrator" />
                            </StackPanel>

                            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" />

                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="SemiBold" Text="Data" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Launch history is kept for 30 days."
                                    TextWrapping="WrapWholeWords" />
                                <Button
                                    x:Name="ClearHistoryButton"
                                    Click="ClearHistoryButton_Click"
                                    Content="Clear history" />
                                <TextBlock
                                    x:Name="HistoryDataStatusTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
