<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PrismMonitor.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PrismMonitor.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Prism Monitor"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <Style x:Key="PageTitleTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
            <Style x:Key="PageStatusTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            </Style>
            <Style x:Key="RowCardStyle" TargetType="Border">
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
            </Style>
            <Style x:Key="ArchitectureBadgeStyle" TargetType="Border">
                <Setter Property="Padding" Value="7,3" />
                <Setter Property="Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style x:Key="DetailLabelTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Left" />
            </Style>
            <Style x:Key="DetailValueTextStyle" TargetType="TextBlock">
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Left" />
            </Style>
            <Style x:Key="DetailValueButtonStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="28" />
                <Setter Property="Padding" Value="0,2,6,2" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="HorizontalContentAlignment" Value="Left" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>
            <Style x:Key="IconCommandButtonStyle" TargetType="Button">
                <Setter Property="MinWidth" Value="34" />
                <Setter Property="Width" Value="34" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Prism Monitor">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <NavigationView
            x:Name="RootNavigationView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            Loaded="Root_Loaded"
            PaneDisplayMode="LeftCompact"
            SelectionChanged="RootNavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="Processes"
                    IsSelected="True"
                    Tag="Processes">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="ViewAll" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="History"
                    Tag="History">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Library" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem
                    Content="Rules"
                    Tag="Rules">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Filter" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Grid Padding="16">
                <Grid
                    x:Name="ProcessesPage"
                    RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="ProcessHeader" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2">
                                <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Compatibility-mode processes" />
                                <TextBlock
                                    x:Name="ProcessStatusTextBlock"
                                    Style="{StaticResource PageStatusTextStyle}"
                                    Text="No active processes" />
                            </StackPanel>
                            <Button
                                Grid.Column="1"
                                AutomationProperties.Name="Refresh processes"
                                Click="RefreshButton_Click"
                                Style="{StaticResource IconCommandButtonStyle}"
                                ToolTipService.ToolTip="Refresh processes">
                                <FontIcon
                                    FontFamily="Segoe Fluent Icons"
                                    FontSize="14"
                                    Glyph="&#xE72C;" />
                            </Button>
                        </Grid>

                        <ListView
                            x:Name="ProcessListView"
                            Grid.Row="1"
                            ItemsSource="{x:Bind Rows, Mode=OneWay}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.HorizontalScrollMode="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollMode="Enabled"
                            SelectionMode="Single">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:ProcessRow">
                                    <Border Style="{StaticResource RowCardStyle}">
                                        <Expander HorizontalAlignment="Stretch">
                                            <Expander.Header>
                                                <Grid MinHeight="48" ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Image Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Center" Source="{x:Bind Icon, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        FontWeight="SemiBold"
                                                        MaxLines="1"
                                                        Text="{x:Bind Name, Mode=OneWay}"
                                                        TextAlignment="Left"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <Border
                                                        x:Name="ProcessArchitectureBadge"
                                                        Grid.Column="2"
                                                        Style="{StaticResource ArchitectureBadgeStyle}">
                                                        <TextBlock FontSize="12" Text="{x:Bind Architecture, Mode=OneWay}" TextAlignment="Left" />
                                                    </Border>
                                                    <TextBlock
                                                        x:Name="ProcessSummaryLine"
                                                        Grid.Column="3"
                                                        VerticalAlignment="Center"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{x:Bind SummaryLine, Mode=OneWay}"
                                                        TextAlignment="Left" />
                                                </Grid>
                                            </Expander.Header>
                                            <StackPanel
                                                x:Name="ProcessDetailsPanel"
                                                Padding="48,0,12,12"
                                                Spacing="8">
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="84" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource DetailLabelTextStyle}" Text="PID" />
                                                        <Button
                                                            x:Name="CopyProcessIdButton"
                                                            Grid.Column="1"
                                                            AutomationProperties.Name="Copy process PID"
                                                            Click="CopyValueButton_Click"
                                                            Style="{StaticResource DetailValueButtonStyle}"
                                                            Tag="{x:Bind ProcessId, Mode=OneWay}"
                                                            ToolTipService.ToolTip="Copy process PID">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <TextBlock
                                                                    x:Name="CopyProcessIdText"
                                                                    Text="{x:Bind ProcessId, Mode=OneWay}"
                                                                    TextAlignment="Left" />
                                                                <FontIcon
                                                                    x:Name="CopyProcessIdGlyph"
                                                                    FontFamily="Segoe Fluent Icons"
                                                                    FontSize="11"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    Glyph="&#xE8C8;" />
                                                            </StackPanel>
                                                        </Button>
                                                    </Grid>
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="84" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource DetailLabelTextStyle}" Text="CPU time" />
                                                        <TextBlock Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" Text="{x:Bind CpuTime, Mode=OneWay}" />
                                                    </Grid>
                                                    <Grid ColumnSpacing="8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="84" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Style="{StaticResource DetailLabelTextStyle}" Text="Path" />
                                                        <TextBlock
                                                            Grid.Column="1"
                                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                            IsTextSelectionEnabled="True"
                                                            Text="{x:Bind ExecutablePath, Mode=OneWay}"
                                                            TextAlignment="Left"
                                                            TextWrapping="Wrap"
                                                            ToolTipService.ToolTip="{x:Bind ExecutablePath, Mode=OneWay}" />
                                                    </Grid>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button
                                                            x:Name="EndProcessButton"
                                                            Click="TerminateMenuItem_Click"
                                                            Content="End process"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="End process" />
                                                        <Button
                                                            x:Name="IgnoreProcessButton"
                                                            Click="IgnoreProcessMenuItem_Click"
                                                            Content="Ignore app"
                                                            Tag="{x:Bind}"
                                                            ToolTipService.ToolTip="Ignore process" />
                                                    </StackPanel>
                                            </StackPanel>
                                        </Expander>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                </Grid>

                <Grid
                    x:Name="HistoryPage"
                    RowSpacing="12"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="HistoryHeader" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Launch history" />
                            <TextBlock
                                x:Name="HistoryStatusTextBlock"
                                Style="{StaticResource PageStatusTextStyle}"
                                Text="No history entries" />
                        </StackPanel>
                        <Button
                            Grid.Column="1"
                            AutomationProperties.Name="Refresh history"
                            Click="RefreshHistoryButton_Click"
                            Style="{StaticResource IconCommandButtonStyle}"
                            ToolTipService.ToolTip="Refresh history">
                            <FontIcon
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Glyph="&#xE72C;" />
                        </Button>
                    </Grid>

                    <ScrollViewer
                        x:Name="HistoryFilterScrollViewer"
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Disabled">
                        <Grid
                            x:Name="HistoryToolbar"
                            Margin="0,2,0,2"
                            ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="144" />
                                <ColumnDefinition Width="144" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="HistorySearchTextBox"
                                PlaceholderText="Search history"
                                TextChanged="HistoryFilter_Changed" />
                            <ComboBox
                                x:Name="HistoryArchitectureComboBox"
                                Grid.Column="1"
                                SelectedIndex="0"
                                SelectedValuePath="Tag"
                                SelectionChanged="HistoryFilter_Changed"
                                x:SuppressXamlTrimWarnings="True">
                                <ComboBoxItem Content="All" Tag="All" />
                                <ComboBoxItem Content="x86" Tag="x86" />
                                <ComboBoxItem Content="x64" Tag="x64" />
                                <ComboBoxItem Content="ARM64EC" Tag="ARM64EC" />
                            </ComboBox>
                            <ComboBox
                                x:Name="HistoryIgnoredStateComboBox"
                                Grid.Column="2"
                                SelectedIndex="0"
                                SelectedValuePath="Tag"
                                SelectionChanged="HistoryFilter_Changed"
                                x:SuppressXamlTrimWarnings="True">
                                <ComboBoxItem Content="All" Tag="All" />
                                <ComboBoxItem Content="Ignored" Tag="Ignored" />
                                <ComboBoxItem Content="Not ignored" Tag="Not ignored" />
                            </ComboBox>
                        </Grid>
                    </ScrollViewer>

                    <ListView
                        x:Name="HistoryListView"
                        Grid.Row="2"
                        ItemsSource="{x:Bind HistoryRows, Mode=OneWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.HorizontalScrollMode="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        ScrollViewer.VerticalScrollMode="Enabled"
                        SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:HistoryRow">
                                <Border Style="{StaticResource RowCardStyle}">
                                    <Expander HorizontalAlignment="Stretch">
                                        <Expander.Header>
                                            <Grid MinHeight="48" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <Image Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Center" Source="{x:Bind Icon, Mode=OneWay}" />
                                                <TextBlock
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    FontWeight="SemiBold"
                                                    MaxLines="1"
                                                    Text="{x:Bind ProcessName, Mode=OneWay}"
                                                    TextAlignment="Left"
                                                    TextTrimming="CharacterEllipsis" />
                                                <Border
                                                    x:Name="HistoryArchitectureBadge"
                                                    Grid.Column="2"
                                                    Style="{StaticResource ArchitectureBadgeStyle}">
                                                    <TextBlock FontSize="12" Text="{x:Bind Architecture, Mode=OneWay}" TextAlignment="Left" />
                                                </Border>
                                                <TextBlock
                                                    x:Name="HistorySummaryLine"
                                                    Grid.Column="3"
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{x:Bind SummaryLine, Mode=OneWay}"
                                                    TextAlignment="Left" />
                                                <TextBlock
                                                    Grid.Column="4"
                                                    VerticalAlignment="Center"
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    Text="{x:Bind IgnoredText, Mode=OneWay}"
                                                    TextAlignment="Left" />
                                            </Grid>
                                        </Expander.Header>
                                        <StackPanel
                                            x:Name="HistoryDetailsPanel"
                                            Padding="48,0,12,12"
                                            Spacing="8">
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="84" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource DetailLabelTextStyle}" Text="PID" />
                                                    <Button
                                                        x:Name="CopyHistoryProcessIdButton"
                                                        Grid.Column="1"
                                                        AutomationProperties.Name="Copy history PID"
                                                        Click="CopyValueButton_Click"
                                                        Style="{StaticResource DetailValueButtonStyle}"
                                                        Tag="{x:Bind LastProcessId, Mode=OneWay}"
                                                        ToolTipService.ToolTip="Copy history PID">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock
                                                                x:Name="CopyHistoryProcessIdText"
                                                                Text="{x:Bind LastProcessId, Mode=OneWay}"
                                                                TextAlignment="Left" />
                                                            <FontIcon
                                                                x:Name="CopyHistoryProcessIdGlyph"
                                                                FontFamily="Segoe Fluent Icons"
                                                                FontSize="11"
                                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                Glyph="&#xE8C8;" />
                                                        </StackPanel>
                                                    </Button>
                                                </Grid>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="84" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource DetailLabelTextStyle}" Text="Seen" />
                                                    <TextBlock
                                                        x:Name="HistoryMetaLine"
                                                        Grid.Column="1"
                                                        Style="{StaticResource DetailValueTextStyle}"
                                                        Text="{x:Bind TimeRangeLine, Mode=OneWay}"
                                                        TextAlignment="Left" />
                                                </Grid>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="84" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Style="{StaticResource DetailLabelTextStyle}" Text="Path" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                        IsTextSelectionEnabled="True"
                                                        Text="{x:Bind ExecutablePath, Mode=OneWay}"
                                                        TextAlignment="Left"
                                                        TextWrapping="Wrap"
                                                        ToolTipService.ToolTip="{x:Bind ExecutablePath, Mode=OneWay}" />
                                                </Grid>
                                                <Button
                                                    x:Name="IgnoreHistoryAppButton"
                                                    HorizontalAlignment="Left"
                                                    Click="IgnoreHistoryAppButton_Click"
                                                    Content="Ignore app"
                                                    Tag="{x:Bind}"
                                                    ToolTipService.ToolTip="Ignore app" />
                                        </StackPanel>
                                    </Expander>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <Grid
                    x:Name="RulesPage"
                    RowSpacing="16"
                    Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            x:Name="RulesHeading"
                            HorizontalAlignment="Left"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="App rules"
                            TextAlignment="Left" />

                        <Grid Grid.Row="1" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RuleNameTextBox" PlaceholderText="Process name rule" />
                            <Button Grid.Column="1" Click="AddRuleButton_Click" Content="Add rule" />
                        </Grid>

                        <ListView
                            x:Name="RuleListView"
                            Grid.Row="2"
                            ItemsSource="{x:Bind RuleRows, Mode=OneWay}"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.HorizontalScrollMode="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
                            ScrollViewer.VerticalScrollMode="Enabled"
                            SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:RuleRow">
                                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid Padding="8,8" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock
                                                    HorizontalAlignment="Left"
                                                    FontWeight="SemiBold"
                                                    Text="{x:Bind DisplayName, Mode=OneWay}"
                                                    TextAlignment="Left"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                    MaxLines="2"
                                                    Text="{x:Bind MatchSummary, Mode=OneWay}"
                                                    TextAlignment="Left"
                                                    TextTrimming="CharacterEllipsis" />
                                                <TextBlock
                                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                    Text="{x:Bind TargetsText, Mode=OneWay}"
                                                    TextAlignment="Left" />
                                            </StackPanel>
                                            <Button
                                                Grid.Column="1"
                                                HorizontalAlignment="Left"
                                                Click="RemoveRuleButton_Click"
                                                Content="Remove"
                                                Tag="{x:Bind Rule, Mode=OneWay}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                </Grid>

                <Grid
                    x:Name="SettingsPage"
                    RowSpacing="16"
                    Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Settings" />

                    <ScrollViewer
                        x:Name="SettingsScrollViewer"
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        VerticalScrollMode="Enabled">
                        <StackPanel Spacing="20" MaxWidth="720" HorizontalAlignment="Left">
                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="SemiBold" Text="Monitoring" />
                                <ToggleSwitch
                                    x:Name="IncludeArm64EcToggle"
                                    Header="Include ARM64EC / ARM64X"
                                    Toggled="IncludeArm64EcToggle_Toggled" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Power-aware refresh pauses while the main window is hidden."
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>

                            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" />

                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="SemiBold" Text="Notifications" />
                                <ComboBox
                                    x:Name="NotificationLevelComboBox"
                                    Header="Notify for"
                                    Width="240"
                                    HorizontalAlignment="Left"
                                    ItemsSource="{x:Bind NotificationLevelOptions, Mode=OneWay}"
                                    SelectionChanged="NotificationLevelComboBox_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate x:DataType="local:NotificationLevelOption">
                                            <TextBlock Text="{x:Bind DisplayName, Mode=OneTime}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" />

                            <StackPanel Spacing="10">
                                <TextBlock FontWeight="SemiBold" Text="Data" />
                                <TextBlock
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="Launch history is kept for 30 days."
                                    TextWrapping="WrapWholeWords" />
                                <Button
                                    x:Name="ClearHistoryButton"
                                    Click="ClearHistoryButton_Click"
                                    Content="Clear history" />
                                <TextBlock
                                    x:Name="HistoryDataStatusTextBlock"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
