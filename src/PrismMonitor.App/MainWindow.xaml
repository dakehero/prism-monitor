<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="PrismMonitor.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PrismMonitor.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Prism Monitor"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Prism Monitor">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Grid Grid.Row="1" Padding="16" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Compatibility-mode processes" />

                <Button
                    Grid.Column="1"
                    Click="RefreshButton_Click"
                    Content="Refresh" />
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="IgnoreNameTextBox"
                    PlaceholderText="Process name to ignore" />
                <Button
                    Grid.Column="1"
                    Click="AddIgnoredButton_Click"
                    Content="Add ignore" />
                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Text="Ignored" />
                <ListView
                    Grid.Column="3"
                    MaxHeight="96"
                    ItemsSource="{x:Bind IgnoredNames, Mode=OneWay}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Text="{x:Bind}"
                                    TextTrimming="CharacterEllipsis" />
                                <Button
                                    Grid.Column="1"
                                    Click="RemoveIgnoredButton_Click"
                                    Content="Remove"
                                    Tag="{x:Bind}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <ListView
                Grid.Row="2"
                ItemsSource="{x:Bind Rows, Mode=OneWay}"
                SelectionMode="None">
                <ListView.Header>
                    <Grid Padding="8,0,8,4" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="Process" />
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="PID" />
                        <TextBlock Grid.Column="3" FontWeight="SemiBold" Text="Arch" />
                        <TextBlock Grid.Column="4" FontWeight="SemiBold" Text="CPU time" />
                        <TextBlock Grid.Column="5" FontWeight="SemiBold" Text="Actions" />
                    </Grid>
                </ListView.Header>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="local:ProcessRow">
                        <Grid Padding="8,4" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>
                            <Image
                                Width="20"
                                Height="20"
                                VerticalAlignment="Center"
                                Source="{x:Bind Icon, Mode=OneWay}" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="{x:Bind Name, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="{x:Bind ProcessId, Mode=OneWay}" />
                            <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="{x:Bind Architecture, Mode=OneWay}" />
                            <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="{x:Bind CpuTime, Mode=OneWay}" />
                            <Button
                                Grid.Column="5"
                                VerticalAlignment="Center"
                                Content="Actions">
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Click="TerminateMenuItem_Click"
                                            Tag="{x:Bind}"
                                            Text="End process" />
                                        <MenuFlyoutItem
                                            Click="IgnoreProcessMenuItem_Click"
                                            Tag="{x:Bind}"
                                            Text="Ignore process" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Window>
